# Cloudflare Turnstile - https://dash.cloudflare.com -> Turnstile
# For local dev, use the official test keys (always pass):
#   site key:   1x00000000000000000000AA
#   secret key: 1x0000000000000000000000000000000AA
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Sheets - service account credentials and target sheet
# Service account is created in Google Cloud Console; share the sheet with its email.
# Keep the literal \n escapes inside the private key string.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEET_ID=
